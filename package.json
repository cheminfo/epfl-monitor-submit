{
  "name": "epfl-monitor-submit",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "./backend",
    "./frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "eslint": "eslint --cache .",
    "eslint-fix": "node --run eslint -- --fix",
    "predev": "lsof -ti:50107,5173 | xargs kill 2>/dev/null || true",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run eslint && npm run prettier",
    "test-only": "NODE_OPTIONS=\"--experimental-webstorage --localstorage-file=:memory:\" vitest --run"
  },
  "devDependencies": {
    "@preact/signals-react-transform": "^0.8.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-zakodium": "^19.1.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.4"
  },
  "volta": {
    "node": "24.14.0"
  }
}
